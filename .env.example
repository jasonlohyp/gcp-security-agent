# GCP Project Configuration
PROJECT_ID=your-gcp-project-id

# BigQuery Log Dataset
BQ_DATASET=your-log-dataset
BQ_LOG_TABLE=cloudrun_googleapis_com_requests

# Vertex AI (Gemini) Configuration
VERTEX_AI_LOCATION=europe-west1
GEMINI_MODEL=gemini-2.5-flash

# Performance & Cost Guards
MAX_WORKERS=10
BQ_COST_PER_GB=0.005
DEFAULT_BQ_GB_PER_QUERY=0.5

# Scan Limits (optional — remove to disable cap)
MAX_PROJECTS=50
TRAFFIC_LOOKBACK_DAYS=30