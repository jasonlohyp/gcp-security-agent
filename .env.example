# GCP Project Configuration
PROJECT_ID=your-gcp-project-id

# BigQuery Log Dataset
# Default GCP log# BigQuery dataset used for storing / querying security findings
BQ_DATASET=your_bigquery_dataset

# Concurrency & Cost Guards
# Max parallel project scans
MAX_WORKERS=10
# BQ pricing (USD per GB scanned)
BQ_COST_PER_GB=0.005
# Heuristic for BQ data scanned per service (GB)
DEFAULT_BQ_GB_PER_QUERY=0.5
BQ_LOG_TABLE=cloudrun_googleapis_com_requests

# Vertex AI (Gemini) Configuration
VERTEX_AI_LOCATION=europe-west1
GEMINI_MODEL=gemini-2.5-flash