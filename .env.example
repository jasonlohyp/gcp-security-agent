# ── GCP Project ───────────────────────────────────────────────────────────────
# Project used for Vertex AI / Gemini auth (who pays for the LLM call).
# This is NOT the scan target — set scan target via CLI (--project / --folder / --org).
PROJECT_ID=your-vertex-ai-project-id

# Optional: pre-set a default scan scope (CLI flags override these)
# FOLDER_ID=123456789
# ORG_ID=987654321

# ── Vertex AI / Gemini ────────────────────────────────────────────────────────
VERTEX_AI_LOCATION=europe-west1
GEMINI_MODEL=gemini-2.5-flash

# ── Traffic Analysis ──────────────────────────────────────────────────────────
# How far back to look for Cloud Run / Cloud Functions request logs.
TRAFFIC_LOOKBACK_DAYS=30

# Max log entries fetched per project in the batch query.
# 500 is sufficient for Active/Inactive classification at any scale.
LOG_BATCH_MAX_RESULTS=500

# ── Report Output ─────────────────────────────────────────────────────────────
# Where HTML reports are written. Use /tmp/reports for Cloud Run deployments.
REPORT_OUTPUT_DIR=output

# ── LLM Prompt Tuning ─────────────────────────────────────────────────────────
# Findings below this threshold are sent to Gemini as full per-service detail.
# At or above this threshold, category-level aggregates are sent instead.
# Prevents token overflow on large org scans (1500 projects x 5 services = 7500 findings).
REPORT_LLM_FINDINGS_THRESHOLD=200

# ── Performance Guards ────────────────────────────────────────────────────────
MAX_WORKERS=10

# Max projects to scan per run. Comment out to disable the cap.
# Recommended: keep a cap during initial testing of new org/folder scans.
MAX_PROJECTS=50
